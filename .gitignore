# ── Database ──
# Track leads.db (14MB, all leads/companies/campaigns data)
# Ignore SQLite journal files (transient, change every request)
*.db-shm
*.db-wal
*.db-journal
/*.sqlite
/*.sqlite3

# ── Runtime data ──
# Default: ignore everything under /data, then un-ignore what matters.
# Large re-downloadable dirs (hf_cache 583MB, models 670MB) stay ignored.
/data/*
!/data/canary_set.json
!/data/recordings/
!/data/adaptive_thresholds.json
!/data/company_bandit.json
!/data/contact_bandit.json
!/data/source_bandit.json
